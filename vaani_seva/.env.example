# Vaani Seva — backend URL for Flutter Web builds
#
# On Vercel: set this as an Environment Variable named API_BASE_URL (not this file).
# Locally:
#   flutter run -d chrome --dart-define=API_BASE_URL=https://your-backend.example.com
#   flutter build web --release --dart-define=API_BASE_URL=https://your-backend.example.com
#
API_BASE_URL=https://your-backend.example.com
